# ─── Node Environment ─────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=runly
POSTGRES_PASSWORD=runly_secret_2026
POSTGRES_DB=runly

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── API Server ───────────────────────────────────────────────
PORT=4000

# ─── Execution Limits ─────────────────────────────────────────
MAX_EXECUTION_TIME_MS=10000
MAX_OUTPUT_BYTES=65536
SANDBOX_MEMORY_MB=256
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=64

# ─── Docker ───────────────────────────────────────────────────
# Export this before running docker compose build:
#   export DOCKER_BUILDKIT=0
DOCKER_BUILDKIT=0
